{
	"$schema": "https://biomejs.dev/schemas/2.5.0/schema.json",
	"assist": {
		"enabled": false
	},
	"linter": {
		"rules": {
			"complexity": {
				"noImportantStyles": "off"
			},
			"style": {
				"noDescendingSpecificity": "off"
			}
		}
	},
	"files": {
		"includes": [
			"**",
			"!**/dist",
			"!**/node_modules",
			"!**/.claude",
			"!**/.local",
			"!**/src-tauri/gen",
			"!**/src-tauri/icons/*.icns",
			"!**/src-tauri/icons/*.png",
			"!**/src-tauri/icons/Square*Logo.png",
			"!**/src-tauri/icons/StoreLogo.png",
			"!**/src-tauri/icons/android",
			"!**/src-tauri/icons/ios",
			"!**/src-tauri/target",
			"!**/src/engine/rad-encoder-wasm/pkg"
		]
	}
}
